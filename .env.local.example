# ============================================================
# MERCHY — Environment Variables
# Copia este archivo a .env.local y llena los valores reales
# ============================================================

# Supabase
# Encuéntralos en: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mercado Pago
# Encuéntralos en: developers.mercadopago.com → Tus integraciones
MERCADOPAGO_ACCESS_TOKEN=your-access-token
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=your-public-key

# Stripe (tarjetas internacionales)
# Encuéntralos en: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
